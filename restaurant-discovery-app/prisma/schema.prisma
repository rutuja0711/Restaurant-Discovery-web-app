generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Restaurant {
  id            Int               @id @default(autoincrement())
  name          String
  cuisine       String
  location      String
  address       String?
  priceRange    String?
  rating        Float             @default(0)
  description   String?
  openingHours  String?
  contactNumber String?
  createdAt     DateTime          @default(now())
  latitude      Float?
  longitude     Float?
  menuItems     MenuItem[]
  images        RestaurantImage[]
 
  ownerId Int?
  owner   Admin? @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  
  reviews     Review[]
  bookings    Booking[]
  
}

model RestaurantImage {
  id           Int        @id @default(autoincrement())
  imageUrl     String
  isPrimary    Boolean    @default(false)
  restaurantId Int
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
}

model MenuItem {
  id           Int        @id @default(autoincrement())
  name         String
  price        String
  restaurantId Int
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
}

model Review {
  id           Int        @id @default(autoincrement())
  reviewerName String
  rating       Int
  comment      String
  createdAt    DateTime   @default(now())
  restaurantId Int
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
}

model User {
  id           Int      @id @default(autoincrement())
  name         String
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}




model Admin {
  id           Int          @id @default(autoincrement())
  name         String
  email        String       @unique
  passwordHash String
  createdAt    DateTime     @default(now())
  restaurants  Restaurant[]
}

model Booking {
  id             Int      @id @default(autoincrement())
  restaurantId   Int
  restaurant     Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  customerName   String
  customerPhone  String
  partySize      Int
  bookingDate    String
  bookingTime    String
  notes          String?
  status         String   @default("pending") // pending, confirmed, declined
  createdAt      DateTime @default(now())
}