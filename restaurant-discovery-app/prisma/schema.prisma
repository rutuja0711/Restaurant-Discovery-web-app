generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Restaurant {
  id               Int               @id @default(autoincrement())
  name             String
  cuisine          String
  location         String
  address          String?
  priceRange       String?
  rating           Float             @default(0)
  description      String?
  openingHours     String?
  contactNumber    String?
  isOpen           Boolean           @default(true)
  slotDuration     Int               @default(45)
  maxGuestsPerSlot Int               @default(20)
  blockedDates     String?
  createdAt        DateTime          @default(now())
  latitude         Float?
  longitude        Float?
  menuItems     MenuItem[]
  images        RestaurantImage[]
  tables        RestaurantTable[]

  ownerId Int?
  owner   Admin? @relation(fields: [ownerId], references: [id], onDelete: SetNull)

  reviews  Review[]
  bookings Booking[]
}

model RestaurantTable {
  id           Int        @id @default(autoincrement())
  tableNumber  String
  capacity     Int
  isIndoor     Boolean    @default(true)
  isVip        Boolean    @default(false)
  isActive     Boolean    @default(true)
  restaurantId Int
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  bookings     Booking[]
}

model RestaurantImage {
  id           Int        @id @default(autoincrement())
  imageUrl     String
  isPrimary    Boolean    @default(false)
  restaurantId Int
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
}

model MenuItem {
  id           Int        @id @default(autoincrement())
  name         String
  price        String
  restaurantId Int
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
}

model Review {
  id           Int        @id @default(autoincrement())
  reviewerName String
  rating       Int
  comment      String
  createdAt    DateTime   @default(now())
  restaurantId Int
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
}

model User {
  id           Int       @id @default(autoincrement())
  name         String
  email        String    @unique
  phone        String?   @unique
  passwordHash String
  createdAt    DateTime  @default(now())
  bookings     Booking[]
}

model Admin {
  id           Int          @id @default(autoincrement())
  name         String
  email        String       @unique
  passwordHash String
  createdAt    DateTime     @default(now())
  restaurants  Restaurant[]
}

model Booking {
  id            Int             @id @default(autoincrement())
  restaurantId  Int
  restaurant    Restaurant      @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  userId        Int?
  user          User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  tableId       Int
  table         RestaurantTable @relation(fields: [tableId], references: [id], onDelete: Cascade)
  customerName  String
  customerPhone String
  partySize     Int
  slotStart     DateTime
  slotEnd       DateTime
  bookingDate   String
  bookingTime   String
  notes         String?
  status        String          @default("pending") // pending, confirmed, declined, cancelled, arrived, completed
  createdAt     DateTime        @default(now())

  @@unique([tableId, slotStart])
}
